{
  "name": "api-spector",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix apps/api-spector-spa",
    "build:spa": "npm run build --prefix apps/api-spector-spa",
    "test:spa": "npm run test --prefix apps/api-spector-spa",
    "build:maven": "npm run build:spa && mvn -f maven/pom.xml clean verify -DskipTests=false",
    "build": "npm run build:maven"
  }
}
